	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>
	<parameter name="fromDate" class="java.lang.String"/>
	<parameter name="toDate" class="java.lang.String"/>
	<parameter name="teritoryId" class="java.lang.String"/>
	<parameter name="divisionId" class="java.lang.String"/>
	<queryString>
		<![CDATA[select  
        Distinct
        v.division_id divisionId,
        v.division_name divisionName,
        v.teritory_id teritoryId,
        v.teritory_name teritoryName,
        b.user_id id,
        b.user_name brId,
        br.name brName,
        ba.attendance_date attendanceDate,
        to_char(ba.attendance_date_time,'DD-MON-YY HH.MI.SS AM') attendanceDateTime
from    appce.bruser_attendance ba
join    appce.bruser b on ba.br_user_user_id=b.user_id
and     ba.attendance_date between to_date($P{fromDate},'DD-MON-YY') and to_date($P{toDate},'DD-MON-YY')
join    appce.v_teritory_all v on b.teritory_id=v.teritory_id
and     ($P{teritoryId} is null or v.teritory_id=$P{teritoryId})
join    appce.brand_representative br on ba.br_user_user_id=br.br_user_user_id
order   by ba.attendance_date,v.division_id,v.teritory_id,b.user_id]]>
	</queryString>
	<field name="divisionId" class="java.math.BigDecimal"/>
	<field name="divisionName" class="java.lang.String"/>
	<field name="teritoryId" class="java.math.BigDecimal"/>
	<field name="teritoryName" class="java.lang.String"/>
	<field name="brId" class="java.lang.String"/>
	<field name="brName" class="java.lang.String"/>
	<field name="attendanceDate" class="java.lang.String"/>
	<field name="attendanceDateTime" class="java.lang.String"/>
